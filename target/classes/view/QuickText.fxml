<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.QuickTextController">
  <children>
    <MenuBar VBox.vgrow="NEVER">
      <menus>
        <Menu mnemonicParsing="false" text="File">
          <items>
          	<Menu mnemonicParsing="false" text="Add">
          		<items>
          			<MenuItem mnemonicParsing="false" fx:id="createFolderMenuItem" disable="true" onAction="#createFolder" text="New Folder" />
          			<Menu mnemonicParsing="false" fx:id="newTemplateMenu" disable="true" text="New Template...">
                     <items>
                        <MenuItem mnemonicParsing="false" onAction="#createHTMLTemplate" text="HTML Template" />
                  		<MenuItem mnemonicParsing="false" onAction="#createPlainTextTemplate" text="Plain-Text Template" />
                     </items>
                  </Menu>
          		</items>
          	</Menu>
          	<Menu mnemonicParsing="false" text="Delete">
          		<items>
          			<MenuItem mnemonicParsing="false" fx:id="deleteTemplateMenuItem" disable="true" onAction="#deleteTemplate" text="Delete Template" />
          			<MenuItem mnemonicParsing="false" fx:id="deleteFolderMenuItem" disable="true" onAction="#deleteFolder" text="Delete Folder" />
            		<MenuItem mnemonicParsing="false" fx:id="deleteAllFoldersMenuItem" disable="true" onAction="#deleteAllFolders" text="Delete All Folders" />
            	</items>
          	</Menu>   
            <MenuItem mnemonicParsing="false" fx:id="importTemplateMenuItem" onAction="#importTemplate" disable="true" text="Import Template" />
            <SeparatorMenuItem mnemonicParsing="false" />
            <MenuItem mnemonicParsing="false" onAction="#exitApplication" text="Quit" />
          </items>
        </Menu>
        <Menu mnemonicParsing="false" text="Settings" />
        <Menu mnemonicParsing="false" text="Help">
          <items>
            <MenuItem mnemonicParsing="false" onAction="#showAboutMenu" text="About" />
          </items>
        </Menu>
      </menus>
    </MenuBar>
    <SplitPane dividerPositions="0.25, 0.7" focusTraversable="true" prefHeight="-1.0" prefWidth="-1.0" VBox.vgrow="ALWAYS">
      <items>
        <ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="-1.0" prefWidth="-1.0">
               <content>
                  <TreeView fx:id="treeView" prefHeight="200.0" prefWidth="200.0" />
               </content>
        </ScrollPane>
            <ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="200.0" prefWidth="200.0">
               <content>
                  <StackPane prefHeight="150.0" prefWidth="200.0">
                     <children>
                        <TextArea fx:id="textArea" editable="false" prefHeight="200.0" prefWidth="200.0" visible="false" />
                        <WebView fx:id="webView" prefHeight="200.0" prefWidth="200.0" visible="false" />
                     </children>
                  </StackPane>
               </content>
            </ScrollPane>
            <ScrollPane fitToHeight="true" fitToWidth="true" prefHeight="200.0" prefWidth="200.0">
               <content>
                  <AnchorPane prefHeight="200.0" prefWidth="200.0">
                     <children>
                        <GridPane AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="50.0">
                          <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                          </columnConstraints>
                          <rowConstraints>
                            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                          </rowConstraints>
                        </GridPane>
                     </children>
                  </AnchorPane>
               </content>
            </ScrollPane>
      </items>
    </SplitPane>
  </children>
</VBox>
